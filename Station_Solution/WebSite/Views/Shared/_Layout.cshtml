@{
    var title = ViewData["Title"] as string ?? "Kahramanlar Belen Akaryakıt";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - Kahramanlar Belen Akaryakıt</title>

    <meta name="description" content="Hatay/Belen Kahramanlar Belen Akaryakıt - Opet Çözüm Ortağı. Canlı akaryakıt fiyatları, hizmetler ve iletişim." />
    <meta name="theme-color" content="#0033a0" />

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />

    <!-- Swiper -->
    <link href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" rel="stylesheet" />

    <!-- Your layout css -->
    <link rel="stylesheet" href="~/css/_layout.css" asp-append-version="true" />
</head>

<body class="app-body">
    <!-- =========================
             NAVBAR (STICKY)
    ========================== -->
    <header class="app-header">
        <nav class="navbar navbar-expand-lg navbar-dark app-navbar fixed-top">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <!-- Logo dosyan varsa: wwwroot/img/khr-logo.svg -->
                    <img src="~/img/khr-logo.svg" alt="KHR" class="brand-logo" onerror="this.style.display='none';" />
                    <span class="brand-text">Kahramanlar Belen Akaryakıt</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Menü">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                        <li class="nav-item"><a class="nav-link" href="#fuel-prices">Fiyatlar</a></li>
                        <li class="nav-item"><a class="nav-link" href="#about">Hakkımızda</a></li>
                        <li class="nav-item"><a class="nav-link" href="#services">Hizmetler</a></li>
                        <li class="nav-item"><a class="nav-link" href="#contact">İletişim</a></li>
                        <li class="nav-item ms-lg-2">
                            <a class="btn btn-opet btn-sm px-3" href="#fuel-prices">
                                <i class="fa-solid fa-bolt me-2"></i>Canlı Fiyat
                            </a>
                        </li>
                        <li class="nav-item ms-lg-2">
                            <a class="btn btn-opet-outline btn-sm px-3"
                               asp-controller="Auth"
                               asp-action="Login"
                               asp-route-returnUrl="@returnUrl">
                                <i class="fa-solid fa-right-to-bracket me-2"></i>Giriş
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- Spacer for fixed navbar -->
    <div class="navbar-spacer"></div>

    <main role="main" class="app-main">
        @RenderBody()
    </main>

    <!-- Scroll to top -->
    <button id="scrollTopBtn" class="scroll-top-btn" type="button" aria-label="Yukarı çık">
        <i class="fa-solid fa-arrow-up"></i>
    </button>

    <!-- =========================
               FOOTER
    ========================== -->
    <footer class="site-footer mt-auto">
        <div class="container py-4">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
                <div class="text-white-50 small">
                    © <span id="footerYear"></span> Kahramanlar Belen Akaryakıt. Tüm hakları saklıdır.
                </div>
                <div class="text-white-50 small">
                    Created by <span class="fw-semibold">B-async Software</span>
                </div>
            </div>
        </div>
    </footer>

    <!-- Bootstrap Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Swiper -->
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

    <!-- Firebase (compat) - Firestore kullanacaksan -->
    <!-- Not: Firebase config'i _layout.js içinde dolduracaksın -->
    <script src="https://www.gstatic.com/firebasejs/10.12.5/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.12.5/firebase-firestore-compat.js"></script>

    <!-- Your layout js -->
    <script src="~/js/_layout.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
