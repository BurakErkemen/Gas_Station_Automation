<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Müşteri Girişi | Petrol Otomasyon</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .login-bg {
            background: rgba(0, 15, 40, 0.85) url('https://images.unsplash.com/photo-1589923186741-b7d59d6b2c4e?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80');
            background-blend-mode: darken;
            background-size: cover;
            background-position: center;
        }
    </style>
</head>
<body class="login-bg min-h-screen flex items-center justify-center p-4">
    <div class="max-w-md w-full">
        <!-- Logo -->
        <div class="text-center mb-10">
            <div class="flex justify-center items-center space-x-2 mb-4">
                <div class="w-12 h-12 bg-gradient-to-br from-blue-900 to-blue-700 rounded-xl"></div>
                <span class="text-3xl font-bold text-white">PetrolOtomasyon</span>
            </div>
            <p class="text-gray-300">Sistem paneline erişmek için giriş yapın</p>
        </div>

        <!-- Login Form -->
        <div class="bg-white/10 backdrop-blur-md rounded-2xl shadow-2xl p-8 border border-white/20">
            <h2 class="text-2xl font-bold text-white mb-6 text-center">Müşteri Girişi</h2>

            <form action="/Account/Login" method="post">
                <div class="mb-6">
                    <label for="username" class="block text-gray-300 mb-2">Kullanıcı Adı</label>
                    <input type="text" id="username" name="username"
                           class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent"
                           placeholder="kullanici@firma.com" required>
                </div>

                <div class="mb-6">
                    <label for="password" class="block text-gray-300 mb-2">Şifre</label>
                    <input type="password" id="password" name="password"
                           class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent"
                           placeholder="••••••••" required>
                </div>

                <div class="flex items-center justify-between mb-8">
                    <div class="flex items-center">
                        <input type="checkbox" id="remember" name="remember" class="w-4 h-4 text-orange-600 bg-white/10 border-white/20 rounded focus:ring-orange-500">
                        <label for="remember" class="ml-2 text-gray-300">Beni Hatırla</label>
                    </div>
                    <a href="#" class="text-orange-400 hover:text-orange-300 text-sm">Şifremi Unuttum?</a>
                </div>

                <button type="submit"
                        class="w-full bg-gradient-to-r from-orange-500 to-orange-600 text-white py-3 rounded-lg font-semibold hover:shadow-lg transition-all duration-300 mb-4">
                    Giriş Yap
                </button>

                <div class="text-center">
                    <a href="/" class="text-gray-300 hover:text-white text-sm flex items-center justify-center">
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                        </svg>
                        Ana Sayfaya Dön
                    </a>
                </div>
            </form>

            <div class="mt-8 pt-6 border-t border-white/20">
                <p class="text-gray-400 text-sm text-center">
                    Giriş sorunu yaşıyorsanız lütfen <br>
                    <a href="mailto:destek@petrolotomasyon.com" class="text-orange-400">destek@petrolotomasyon.com</a> ile iletişime geçin.
                </p>
            </div>
        </div>

        <div class="mt-8 text-center">
            <p class="text-gray-400 text-sm">© 2023 Petrol Otomasyon A.Ş. • Tüm hakları saklıdır.</p>
        </div>
    </div>
</body>
</html>