<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Kahramanlar Belen Akaryakıt</title>

    <!-- CSS Dosyaları -->
    <link rel="stylesheet" href="~/css/_layout.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@10/swiper-bundle.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Roboto:wght@300;400;500&display=swap" rel="stylesheet">

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Header & Navigation -->
    <header class="sticky-top">
        <div class="container">
            <div class="header-content">
                <!-- Logo -->
                <div class="logo">
                    <div class="logo-icon">KB</div>
                    <div>
                        <h1 class="logo-title">Kahramanlar Belen Akaryakıt</h1>
                        <p class="logo-subtitle">Hatay/Belen • 2012'den Beri Hizmetinizde</p>
                    </div>
                </div>

                <!-- Navigation -->
                <nav class="main-nav">
                    <ul>
                        <li><a href="#home" class="nav-active">Ana Sayfa</a></li>
                        <li><a href="#about">Hakkımızda</a></li>
                        <li><a href="#services">Hizmetlerimiz</a></li>
                        <li><a href="#gallery">Galeri</a></li>
                        <li><a href="#contact">İletişim</a></li>
                    </ul>
                </nav>

                <!-- Mobile Menu Button -->
                <button id="mobileMenuBtn" class="mobile-menu-btn">
                    <i class="fas fa-bars"></i>
                </button>
            </div>
        </div>

        <!-- Mobile Menu -->
        <div id="mobileMenu" class="mobile-menu">
            <ul>
                <li><a href="#home" class="mobile-nav-link">Ana Sayfa</a></li>
                <li><a href="#about" class="mobile-nav-link">Hakkımızda</a></li>
                <li><a href="#services" class="mobile-nav-link">Hizmetlerimiz</a></li>
                <li><a href="#gallery" class="mobile-nav-link">Galeri</a></li>
                <li><a href="#contact" class="mobile-nav-link">İletişim</a></li>
            </ul>

            <!-- İletişim Bilgileri (Mobil) -->
            <div class="mobile-contact">
                <div class="contact-item">
                    <i class="fas fa-phone-alt"></i>
                    <span>+90 530 525 10 50</span>
                </div>
                <div class="contact-item">
                    <i class="fas fa-clock"></i>
                    <span><span class="open-status open"></span> 24 Saat Açık</span>
                </div>
            </div>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer-grid">
                <div class="footer-col">
                    <div class="footer-logo">
                        <div class="logo-icon">KB</div>
                        <h3>Kahramanlar Belen Akaryakıt</h3>
                    </div>
                    <p class="footer-description">2012 yılından beri Belen ve çevresine kaliteli akaryakıt hizmeti sunan, güvenilir ve köklü bir aile işletmesiyiz.</p>
                    <div class="social-links">
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                    </div>
                </div>

                <div class="footer-col">
                    <h4 class="footer-title">Hızlı Erişim</h4>
                    <ul class="footer-links">
                        <li><a href="#home">Ana Sayfa</a></li>
                        <li><a href="#about">Hakkımızda</a></li>
                        <li><a href="#services">Hizmetlerimiz</a></li>
                        <li><a href="#gallery">Galeri</a></li>
                        <li><a href="#contact">İletişim</a></li>
                    </ul>
                </div>

                <div class="footer-col">
                    <h4 class="footer-title">İletişim Bilgileri</h4>
                    <ul class="footer-contact">
                        <li>
                            <i class="fas fa-map-marker-alt"></i>
                            <span>İstiklal Mahallesi, Atatürk Bulvarı No: 45, Belen, Hatay</span>
                        </li>
                        <li>
                            <i class="fas fa-phone-alt"></i>
                            <span>+90 530 525 10 50</span>
                        </li>
                        <li>
                            <i class="fas fa-envelope"></i>
                            <span>info@kahramanlarakaryakit.com</span>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="footer-bottom">
                <p>&copy; 2026 Kahramanlar Belen Akaryakıt. Tüm hakları saklıdır.</p>
                <p class="footer-note">Created by B-async Software </p>
            </div>
        </div>
    </footer>

    <!-- Script Dosyaları -->
    <script src="https://cdn.jsdelivr.net/npm/swiper@10/swiper-bundle.min.js"></script>
    <script src="~/js/_layout.js"></script>
    <script src="~/js/site.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>