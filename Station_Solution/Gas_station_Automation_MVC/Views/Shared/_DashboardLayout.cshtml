@using System.Security.Claims
@{
    var role = User.FindFirst(ClaimTypes.Role)?.Value?.ToLowerInvariant() ?? "customer";
    var userName = User.FindFirst(ClaimTypes.Name)?.Value ?? "Kullanıcı";
    var page = (ViewData["Page"] as string ?? "dashboard").ToLowerInvariant();

    // Role label (UI)
    var roleLabel = role switch
    {
        "admin" => "Admin",
        "moderator" => "Moderatör",
        _ => "Müşteri"
    };

    // Brand accent (role based)
    var accentBorder = role switch
    {
        "admin" => "border-blue-500",
        "moderator" => "border-green-500",
        _ => "border-purple-500"
    };

    var accentBg = role switch
    {
        "admin" => "bg-blue-600",
        "moderator" => "bg-emerald-600",
        _ => "bg-purple-600"
    };

    var accentBgDark = role switch
    {
        "admin" => "bg-blue-700",
        "moderator" => "bg-emerald-700",
        _ => "bg-purple-700"
    };

    bool isAdmin = role == "admin";
    bool isModerator = role == "moderator";
    bool isCustomer = role == "customer";
}
<!DOCTYPE html>
<html lang="tr" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Kahramanlar Belen Akaryakıt</title>

    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/apexcharts/3.35.0/apexcharts.min.css" />

    <style>
        .sidebar {
            transition: all 0.3s ease;
        }

        .active-nav {
            background-color: rgba(255,255,255,0.10);
            border-left: 4px solid;
        }

        .chip {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            padding: .25rem .6rem;
            border-radius: 999px;
            font-size: .75rem;
            background: rgba(255,255,255,.08);
            border: 1px solid rgba(255,255,255,.10);
        }

        .sidebar-scroll {
            height: calc(100vh - 140px);
            overflow-y: auto;
        }

            .sidebar-scroll::-webkit-scrollbar {
                width: 8px;
            }

            .sidebar-scroll::-webkit-scrollbar-thumb {
                background: rgba(255,255,255,.12);
                border-radius: 999px;
            }
    </style>

    @RenderSection("Styles", required: false)
</head>

<body class="h-full bg-gray-50">
    <div class="flex h-screen">

        <!-- Sidebar -->
        <aside class="sidebar w-64 bg-gray-900 text-white relative">

            <!-- Brand -->
            <div class="p-6 border-b border-gray-800">
                <div class="flex items-center space-x-3">
                    <div class="w-10 h-10 @accentBg rounded-lg flex items-center justify-center">
                        <i class="fas fa-gas-pump text-white"></i>
                    </div>
                    <div>
                        <h1 class="text-lg font-bold leading-tight">Kahramanlar Belen</h1>
                        <p class="text-xs text-gray-400">Akaryakıt İstasyonu</p>
                    </div>
                </div>

                <div class="mt-4 flex items-center justify-between">
                    <span class="chip">
                        <i class="fas fa-shield-alt"></i>
                        @roleLabel
                    </span>

                    @* Hızlı aksiyonlar (role göre) *@
                    <div class="flex items-center gap-2">
                        @if (isAdmin)
                        {
                            <a href="/AdminDashboard/Users" class="text-gray-300 hover:text-white" title="Kullanıcı Yönetimi">
                                <i class="fas fa-user-plus"></i>
                            </a>
                        }
                        @if (isAdmin || isModerator)
                        {
                            <a href="/ModeratorDashboard/Shifts" class="text-gray-300 hover:text-white" title="Vardiya">
                                <i class="fas fa-clipboard-list"></i>
                            </a>
                            <a href="/ModeratorDashboard/Invoices" class="text-gray-300 hover:text-white" title="Fatura">
                                <i class="fas fa-file-invoice-dollar"></i>
                            </a>
                        }
                        @if (isCustomer)
                        {
                            <a href="/CustomerDashboard/MyDebts" class="text-gray-300 hover:text-white" title="Borçlarım">
                                <i class="fas fa-credit-card"></i>
                            </a>
                        }
                    </div>
                </div>
            </div>

            <!-- Menu -->
            <div class="px-4 py-4 sidebar-scroll">
                <p class="text-xs text-gray-400 uppercase tracking-wider mb-2">Ana Menü</p>

                <nav class="space-y-1">

                    @* Admin: Moderator menülerinin tamamı + ekstra *@
                    @if (isAdmin)
                    {
                        <a href="/AdminDashboard" class="flex items-center px-4 py-3 text-gray-300 hover:bg-gray-800 rounded-lg @(page == "dashboard" ? $"active-nav {accentBorder}" : "")">
                            <i class="fas fa-tachometer-alt mr-3"></i><span>Genel Dashboard</span>
                        </a>

                        <p class="mt-4 mb-2 text-xs text-gray-500 uppercase tracking-wider">Operasyon</p>

                        <a href="/ModeratorDashboard/Shifts" class="flex items-center px-4 py-3 text-gray-300 hover:bg-gray-800 rounded-lg @(page == "shifts" ? $"active-nav {accentBorder}" : "")">
                            <i class="fas fa-clipboard-list mr-3"></i><span>Vardiyalar</span>
                        </a>

                        <a href="/ModeratorDashboard/Invoices" class="flex items-center px-4 py-3 text-gray-300 hover:bg-gray-800 rounded-lg @(page == "invoices" ? $"active-nav {accentBorder}" : "")">
                            <i class="fas fa-file-invoice-dollar mr-3"></i><span>Faturalar</span>
                        </a>

                        <a href="/ModeratorDashboard/Transactions" class="flex items-center px-4 py-3 text-gray-300 hover:bg-gray-800 rounded-lg @(page == "transactions" ? $"active-nav {accentBorder}" : "")">
                            <i class="fas fa-exchange-alt mr-3"></i><span>Satış İşlemleri</span>
                        </a>

                        <p class="mt-4 mb-2 text-xs text-gray-500 uppercase tracking-wider">Yönetim</p>

                        <a href="/AdminDashboard/Users" class="flex items-center px-4 py-3 text-gray-300 hover:bg-gray-800 rounded-lg @(page == "users" ? $"active-nav {accentBorder}" : "")">
                            <i class="fas fa-users mr-3"></i><span>Kullanıcılar</span>
                        </a>

                        <a href="/AdminDashboard/Reports" class="flex items-center px-4 py-3 text-gray-300 hover:bg-gray-800 rounded-lg @(page == "reports" ? $"active-nav {accentBorder}" : "")">
                            <i class="fas fa-chart-bar mr-3"></i><span>Raporlar</span>
                        </a>

                        <a href="/AdminDashboard/Settings" class="flex items-center px-4 py-3 text-gray-300 hover:bg-gray-800 rounded-lg @(page == "settings" ? $"active-nav {accentBorder}" : "")">
                            <i class="fas fa-cog mr-3"></i><span>Ayarlar</span>
                        </a>
                    }
                    else if (isModerator)
                    {
                        <a href="/ModeratorDashboard" class="flex items-center px-4 py-3 text-gray-300 hover:bg-gray-800 rounded-lg @(page == "dashboard" ? $"active-nav {accentBorder}" : "")">
                            <i class="fas fa-tachometer-alt mr-3"></i><span>Dashboard</span>
                        </a>

                        <a href="/ModeratorDashboard/Shifts" class="flex items-center px-4 py-3 text-gray-300 hover:bg-gray-800 rounded-lg @(page == "shifts" ? $"active-nav {accentBorder}" : "")">
                            <i class="fas fa-clipboard-list mr-3"></i><span>Vardiyalar</span>
                        </a>

                        <a href="/ModeratorDashboard/Invoices" class="flex items-center px-4 py-3 text-gray-300 hover:bg-gray-800 rounded-lg @(page == "invoices" ? $"active-nav {accentBorder}" : "")">
                            <i class="fas fa-file-invoice-dollar mr-3"></i><span>Faturalar</span>
                        </a>

                        <a href="/ModeratorDashboard/Transactions" class="flex items-center px-4 py-3 text-gray-300 hover:bg-gray-800 rounded-lg @(page == "transactions" ? $"active-nav {accentBorder}" : "")">
                            <i class="fas fa-exchange-alt mr-3"></i><span>Satış İşlemleri</span>
                        </a>
                    }
                    else
                    {
                        <a href="/CustomerDashboard" class="flex items-center px-4 py-3 text-gray-300 hover:bg-gray-800 rounded-lg @(page == "dashboard" ? $"active-nav {accentBorder}" : "")">
                            <i class="fas fa-home mr-3"></i><span>Ana Sayfa</span>
                        </a>

                        <a href="/CustomerDashboard/MyDebts" class="flex items-center px-4 py-3 text-gray-300 hover:bg-gray-800 rounded-lg @(page == "debts" ? $"active-nav {accentBorder}" : "")">
                            <i class="fas fa-credit-card mr-3"></i><span>Borçlarım</span>
                        </a>

                        <a href="/CustomerDashboard/Transactions" class="flex items-center px-4 py-3 text-gray-300 hover:bg-gray-800 rounded-lg @(page == "transactions" ? $"active-nav {accentBorder}" : "")">
                            <i class="fas fa-history mr-3"></i><span>İşlemlerim</span>
                        </a>

                        <a href="/CustomerDashboard/Payments" class="flex items-center px-4 py-3 text-gray-300 hover:bg-gray-800 rounded-lg @(page == "payments" ? $"active-nav {accentBorder}" : "")">
                            <i class="fas fa-money-check-alt mr-3"></i><span>Ödemelerim</span>
                        </a>
                    }
                </nav>
            </div>

            <!-- User footer -->
            <div class="absolute bottom-0 w-64 p-6 border-t border-gray-800 bg-gray-900">
                <div class="flex items-center space-x-3">
                    <div class="w-10 h-10 @accentBg rounded-full flex items-center justify-center">
                        <i class="fas fa-user text-white"></i>
                    </div>
                    <div class="flex-1">
                        <p class="font-medium leading-tight">@userName</p>
                        <p class="text-xs text-gray-400">@roleLabel</p>
                    </div>

                    <form asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="text-gray-400 hover:text-white" title="Çıkış Yap">
                            <i class="fas fa-sign-out-alt"></i>
                        </button>
                    </form>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <div class="flex-1 overflow-y-auto">
            <!-- Top Bar -->
            <header class="bg-white shadow-sm border-b">
                <div class="px-6 py-4">
                    <div class="flex items-center justify-between">
                        <div>
                            <h2 class="text-xl font-semibold text-gray-800">@ViewData["Title"]</h2>
                            <p class="text-sm text-gray-600">Hoş geldiniz, @userName</p>
                        </div>

                        <div class="flex items-center space-x-4">
                            @* Role göre mini aksiyon butonu *@
                            @if (isAdmin)
                            {
                                <a href="/AdminDashboard/Users" class="inline-flex items-center gap-2 px-3 py-2 rounded-lg text-white @accentBg hover:@accentBgDark">
                                    <i class="fas fa-user-plus"></i>
                                    <span class="text-sm font-medium">Yeni Üye</span>
                                </a>
                            }

                            <div class="relative">
                                <i class="fas fa-bell text-gray-500"></i>
                                <span class="absolute -top-1 -right-1 w-3 h-3 bg-red-500 rounded-full"></span>
                            </div>
                            <div class="text-sm">
                                <span class="text-gray-600">@DateTime.Now.ToString("dd MMMM yyyy")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </header>

            <main class="p-6">
                @RenderBody()
            </main>
        </div>

    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/apexcharts/3.35.0/apexcharts.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
