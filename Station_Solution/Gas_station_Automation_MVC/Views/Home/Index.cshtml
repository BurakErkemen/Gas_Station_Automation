@{
    ViewData["Title"] = "Kahramanlar Belen Akaryakıt | Hatay/Belen'in Güvenilir Enerji Noktası";
}

<!-- Hero Slider -->
<section id="home" class="hero-section">
    <!-- Slider Container -->
    <div class="swiper mySwiper">
        <div class="swiper-wrapper">
            <!-- Slide 1 -->
            <div class="swiper-slide slide-1">
                <div class="hero-overlay">
                    <div class="container">
                        <div class="hero-content">
                            <h2 class="hero-title">Kaliteli Akaryakıt, Güvenli Yolculuk</h2>
                            <p class="hero-description">2012 yılından beri Belen ve çevresine kaliteli akaryakıt hizmeti sunmaktayız. Benzinde ve motorinde kalite standartlarını en üst seviyede tutuyoruz.</p>
                            <a href="#contact" class="btn btn-primary">İletişime Geç</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Slide 2 -->
            <div class="swiper-slide slide-2">
                <div class="hero-overlay">
                    <div class="container">
                        <div class="hero-content">
                            <h2 class="hero-title">7/24 Hizmetinizdeyiz</h2>
                            <p class="hero-description">Gece gündüz, haftanın 7 günü sizlere hizmet vermekten mutluluk duyuyoruz. Yolculuğunuz ne zaman başlarsa başlasın, biz buradayız.</p>
                            <a href="#services" class="btn btn-primary">Hizmetlerimiz</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Slide 3 -->
            <div class="swiper-slide slide-3">
                <div class="hero-overlay">
                    <div class="container">
                        <div class="hero-content">
                            <h2 class="hero-title">Modern Tesis, Hijyenik Ortam</h2>
                            <p class="hero-description">Tesisimiz modern ekipmanlarla donatılmış olup, hijyen ve temizliğe büyük önem veriyoruz. Siz değerli müşterilerimiz için en iyisini sunuyoruz.</p>
                            <a href="#gallery" class="btn btn-primary">Galeriyi Gör</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Slider Navigation -->
        <div class="swiper-button-next"></div>
        <div class="swiper-button-prev"></div>

        <!-- Slider Pagination -->
        <div class="swiper-pagination"></div>
    </div>
</section>

<!-- Hakkımızda -->
<section id="about" class="about-section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Hakkımızda</h2>
            <p class="section-description">Belen'in ilk ve öncü akaryakıt istasyonlarından olarak, 25 yılı aşkın süredir bölge halkına hizmet veriyoruz.</p>
        </div>

        <div class="about-content">
            <div class="about-text">
                <h3 class="about-subtitle">Kahramanlar Belen Akaryakıt</h3>
                <p>2012 yılında Hatay'ın Belen ilçesinde kurulan istasyonumuz, bölgenin en güvenilir akaryakıt noktalarından biridir. Aile şirketi olarak başladığımız bu yolda, ikinci nesil olarak hizmet vermeye devam ediyoruz.</p>
                <p>Misyonumuz, müşterilerimize en kaliteli akaryakıt ürünlerini sunmak ve yolculuklarını güvenle tamamlamalarını sağlamaktır. Tüm ürünlerimiz uluslararası kalite standartlarına uygun olup, düzenli kalite kontrollerinden geçmektedir.</p>
                <p>İstasyonumuzda sadece akaryakıt satışı değil, aynı zamanda araç bakım noktaları, temizlik hizmetleri ve müşteri dinlenme alanları bulunmaktadır.</p>

                <div class="stats-grid">
                    <div class="stat-item">
                        <div class="stat-number" style="color: var(--primary-red);">25+</div>
                        <div class="stat-label">Yıllık Tecrübe</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-number" style="color: var(--primary-blue);">7/24</div>
                        <div class="stat-label">Kesintisiz Hizmet</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-number" style="color: var(--primary-yellow);">100%</div>
                        <div class="stat-label">Müşteri Memnuniyeti</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-number" style="color: #28a745;">4.0</div>
                        <div class="stat-label">Ortalama Puan</div>
                    </div>
                </div>
            </div>

            <div class="about-image">
                <img src="~/images/station.png" alt="Kahramanlar Belen Akaryakıt İstasyonu">
                <div class="certificate-badge">
                    <div class="certificate-icon">
                        <i class="fas fa-award"></i>
                    </div>
                    <div>
                        <h4>Kalite Belgelidir</h4>
                        <p>TSE ve ISO Sertifikalı</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Hizmetlerimiz -->
<section id="services" class="services-section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Hizmetlerimiz</h2>
            <p class="section-description">İstasyonumuzda sunduğumuz birbirinden kaliteli hizmetler</p>
        </div>

        <div class="services-grid">
            <!-- Hizmet 1 -->
            <div class="service-card">
                <div class="service-icon">
                    <i class="fas fa-gas-pump"></i>
                </div>
                <h3 class="service-title">Akaryakıt Satışı</h3>
                <ul class="service-features">
                    <li><i class="fas fa-check-circle"></i> Premium Benzin (95 Oktan)</li>
                    <li><i class="fas fa-check-circle"></i> Motorin (Dizel)</li>
                    <li><i class="fas fa-check-circle"></i> LPG (Otogaz)</li>
                    <li><i class="fas fa-check-circle"></i> Euro Diesel</li>
                </ul>
            </div>

            <!-- Hizmet 2 -->
            <div class="service-card">
                <div class="service-icon">
                    <i class="fas fa-car"></i>
                </div>
                <h3 class="service-title">Araç Bakım Hizmetleri</h3>
                <ul class="service-features">
                    <li><i class="fas fa-check-circle"></i> Lastik Hava Basıncı Kontrolü</li>
                    <li><i class="fas fa-check-circle"></i> Cam Silme Sıvısı Doldurma</li>
                    <li><i class="fas fa-check-circle"></i> Temel Araç Kontrolleri</li>
                    <li><i class="fas fa-check-circle"></i> Araç İçi Temizlik</li>
                </ul>
            </div>

            <!-- Hizmet 3 -->
            <div class="service-card">
                <div class="service-icon">
                    <i class="fas fa-store"></i>
                </div>
                <h3 class="service-title">Market & Dinlenme</h3>
                <ul class="service-features">
                    <li><i class="fas fa-check-circle"></i> Yolcu Dinlenme Alanı</li>
                    <li><i class="fas fa-check-circle"></i> Otobil</li>
                    <li><i class="fas fa-check-circle"></i> Ultramarket</li>
                    <li><i class="fas fa-check-circle"></i> Ultracafe</li>
                    <li><i class="fas fa-check-circle"></i> Fasty Fırın</li>
                    <li><i class="fas fa-check-circle"></i> Nescafe Corner</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- Akaryakıt Fiyatları -->
<section class="pricing-section">
    <div class="container">
        <div class="pricing-grid">
            <!-- Fiyat Listesi -->
            <div class="pricing-content">
                <h2 class="section-title">Güncel Akaryakıt Fiyatları</h2>
                <p class="pricing-description">Fiyatlarımız güncel olup, perakende satış fiyatlarıdır. Toptan alımlar için lütfen iletişime geçiniz.</p>

                <div class="fuel-prices">
                    <h3>Litre Fiyatları (TL)</h3>

                    <div class="fuel-price-item">
                        <div class="fuel-type">
                            <i class="fas fa-gas-pump"></i>
                            <span>Premium Benzin (95)</span>
                        </div>
                        <div class="fuel-price">38.95</div>
                    </div>

                    <div class="fuel-price-item">
                        <div class="fuel-type">
                            <i class="fas fa-truck-moving"></i>
                            <span>Motorin (Dizel)</span>
                        </div>
                        <div class="fuel-price">36.75</div>
                    </div>

                    <div class="fuel-price-item">
                        <div class="fuel-type">
                            <i class="fas fa-fire"></i>
                            <span>LPG (Otogaz)</span>
                        </div>
                        <div class="fuel-price">22.45</div>
                    </div>

                    <div class="fuel-price-item">
                        <div class="fuel-type">
                            <i class="fas fa-industry"></i>
                            <span>Euro Diesel</span>
                        </div>
                        <div class="fuel-price">37.25</div>
                    </div>

                    <div class="price-update">
                        <p>Fiyatlar günlük olarak güncellenmektedir. Son güncelleme: 15.10.2023</p>
                    </div>
                </div>
            </div>

            <!-- Çalışma Saatleri ve İletişim -->
            <div class="hours-contact">
                <h2 class="section-title">Çalışma Saatleri & İletişim</h2>

                <div class="hours-card">
                    <h3>Çalışma Saatleri</h3>

                    <div class="hours-list">
                        <div class="hours-item">
                            <span>Pazartesi - Cuma</span>
                            <span class="hours-open">24 Saat</span>
                        </div>
                        <div class="hours-item">
                            <span>Cumartesi</span>
                            <span class="hours-open">24 Saat</span>
                        </div>
                        <div class="hours-item">
                            <span>Pazar</span>
                            <span class="hours-open">24 Saat</span>
                        </div>
                    </div>

                    <div class="hours-note">
                        <i class="fas fa-info-circle"></i>
                        <span>İstasyonumuz haftanın 7 günü 24 saat açıktır.</span>
                    </div>
                </div>

                <div class="contact-cards">
                    <div class="contact-card">
                        <i class="fas fa-phone-alt"></i>
                        <h4>Telefon</h4>
                        <p>+90 530 525 10 50</p>
                    </div>

                    <div class="contact-card">
                        <i class="fas fa-envelope"></i>
                        <h4>E-Posta</h4>
                        <p>info@kahramanlarakaryakit.com</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Galeri -->
<section id="gallery" class="gallery-section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Galeri</h2>
            <p class="section-description">İstasyonumuzdan ve hizmetlerimizden kareler</p>
        </div>

        <div class="gallery-grid">
            <div class="gallery-item">
                <img src="~/images/station.png" alt="İstasyon Görünümü">
                <div class="gallery-caption">
                    <h4>Modern İstasyonumuz</h4>
                </div>
            </div>

            <div class="gallery-item">
                <img src="~/images/pompa.png" alt="Akaryakıt Pompaları">
                <div class="gallery-caption">
                    <h4>Akaryakıt Pompalarımız</h4>
                </div>
            </div>

            <div class="gallery-item">
                <div class="gallery-video-container">
                    <video controls playsinline preload="metadata">
                        <source src="~/images/video.mp4" type="video/mp4">
                        Tarayıcınız video etiketini desteklemiyor.
                    </video>
                </div>
                <div class="gallery-caption">
                    <h4>Müşteri Hizmetlerimizden Bir Kare</h4>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- İletişim -->
<section id="contact" class="contact-section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">İletişim</h2>
            <p class="section-description">Bize ulaşmak için aşağıdaki iletişim bilgilerini kullanabilir veya haritadaki konumumuzu ziyaret edebilirsiniz.</p>
        </div>

        <div class="contact-grid">
            <!-- İletişim Bilgileri -->
            <div class="contact-info">
                <h3>İletişim Bilgileri</h3>

                <div class="contact-details">
                    <div class="contact-item">
                        <div class="contact-icon">
                            <i class="fas fa-map-marker-alt"></i>
                        </div>
                        <div>
                            <h4>Adres</h4>
                            <p>Halilbey Mah. Mehmet Aslan Cad. no:5/1<br>Belen, Hatay</p>
                        </div>
                    </div>

                    <div class="contact-item">
                        <div class="contact-icon">
                            <i class="fas fa-phone-alt"></i>
                        </div>
                        <div>
                            <h4>Telefon</h4>
                            <p> +90 501 369 7638</p>
                            <small>7/24 Hizmet Hattı</small>
                        </div>
                    </div>

                    <div class="contact-item">
                        <div class="contact-icon">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <div>
                            <h4>E-Posta</h4>
                            <p>info@kahramanlarakaryakit.com</p>
                            <p>satin@kahramanlarakaryakit.com (Toptan Alım)</p>
                        </div>
                    </div>

                    <div class="contact-item">
                        <div class="contact-icon">
                            <i class="fas fa-clock"></i>
                        </div>
                        <div>
                            <h4>Çalışma Saatleri</h4>
                            <p>Haftanın 7 Günü, 24 Saat</p>
                            <small>Bayram ve resmi tatillerde de açığız</small>
                        </div>
                    </div>
                </div>

                <div class="social-media">
                    <h4>Sosyal Medya</h4>
                    <div class="social-icons">
                        <a href="https://www.facebook.com/kahramanopet/" class="social-icon"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="social-icon"><i class="fab fa-twitter"></i></a>
                        <a href="https://www.instagram.com/kahramanlaropetbelen/" class="social-icon"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="social-icon"><i class="fab fa-whatsapp"></i></a>
                    </div>
                </div>
            </div>

            <!-- Harita -->
            <div class="contact-map">
                <h3>Konumumuz</h3>

                <div class="map-container">
                    <iframe src="https://www.google.com/maps?q=36.4896326208134,36.21056758154334&z=15&output=embed"
                            width="100%"
                            height="100%"
                            style="border:0;"
                            allowfullscreen=""
                            loading="lazy"
                            referrerpolicy="no-referrer-when-downgrade">
                    </iframe>
                </div>

                <div class="directions">
                    <h4>Yol Tarifi</h4>
                    <p>Hatay-Antakya yolu üzerinde, Belen ilçe merkezinde, ana cadde üzerinde bulunmaktayız. İskenderun'dan gelirken Belen çıkışında sol tarafta kalmaktayız.</p>
                    <p>İstasyonumuzun önünde geniş bir otopark alanı bulunmaktadır.</p>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Swiper Slider Başlatma
        document.addEventListener('DOMContentLoaded', function() {
            const swiper = new Swiper('.mySwiper', {
                slidesPerView: 1,
                spaceBetween: 0,
                loop: true,
                autoplay: {
                    delay: 5000,
                    disableOnInteraction: false,
                },
                pagination: {
                    el: '.swiper-pagination',
                    clickable: true,
                },
                navigation: {
                    nextEl: '.swiper-button-next',
                    prevEl: '.swiper-button-prev',
                },
            });
        });
    </script>
}