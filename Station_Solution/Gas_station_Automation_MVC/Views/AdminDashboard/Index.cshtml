@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
    <div class="bg-white rounded-xl shadow-sm p-6 border">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-sm text-gray-500">Toplam Kullanıcı</p>
                <p class="text-2xl font-bold text-gray-800">156</p>
            </div>
            <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-users text-blue-600"></i>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm p-6 border">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-sm text-gray-500">Aktif Vardiya</p>
                <p class="text-2xl font-bold text-gray-800">3</p>
            </div>
            <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-clipboard-check text-green-600"></i>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm p-6 border">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-sm text-gray-500">Bugünkü Ciro</p>
                <p class="text-2xl font-bold text-gray-800">45.250₺</p>
            </div>
            <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-chart-line text-purple-600"></i>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm p-6 border">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-sm text-gray-500">Toplam Borç</p>
                <p class="text-2xl font-bold text-gray-800">125.400₺</p>
            </div>
            <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-money-check-alt text-red-600"></i>
            </div>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="bg-white rounded-xl shadow-sm p-6 border">
        <h3 class="text-lg font-semibold mb-4">Son İşlemler</h3>
        <div class="space-y-4">
            <!-- İşlem listesi buraya -->
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm p-6 border">
        <h3 class="text-lg font-semibold mb-4">Sistem İstatistikleri</h3>
        <div id="chart"></div>
    </div>
</div>

@section Scripts {
    <script>
        var options = {
            series: [{
                name: 'Satışlar',
                data: [30, 40, 35, 50, 49, 60, 70, 91, 125]
            }],
            chart: {
                height: 350,
                type: 'line',
                zoom: {
                    enabled: false
                }
            },
            dataLabels: {
                enabled: false
            },
            stroke: {
                curve: 'straight'
            },
            grid: {
                row: {
                    colors: ['#f3f3f3', 'transparent'],
                    opacity: 0.5
                },
            },
            xaxis: {
                categories: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep'],
            }
        };

        var chart = new ApexCharts(document.querySelector("#chart"), options);
        chart.render();
    </script>
}